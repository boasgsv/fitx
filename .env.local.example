# Supabase — create a project at https://supabase.com/dashboard and copy these
# from Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Optional: the site URL used in magic-link redirect emails (defaults to the
# request origin in dev). Set in production to your deployed URL.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: enables the "your partner just logged an activity" nudge email.
# Get an API key at https://resend.com (same account as your SMTP). Without
# RESEND_API_KEY the nudge is simply skipped. RESEND_FROM must be a verified
# sender; onboarding@resend.dev works for testing to your own address.
RESEND_API_KEY=""
RESEND_FROM="FitX <onboarding@resend.dev>"
